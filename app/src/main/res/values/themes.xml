<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Babushka" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bg_app</item>
        <item name="colorPrimaryVariant">@color/bg_header</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <item name="colorSecondary">@color/accent_soft</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- App background -->
        <item name="android:windowBackground">@color/bg_app</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_app</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Font -->
        <item name="android:fontFamily">@font/b612</item>
        <item name="fontFamily">@font/b612</item>
    </style>
</resources>