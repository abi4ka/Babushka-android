<androidx.constraintlayout.widget.ConstraintLayout xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_weight="1"
    android:layout_marginStart="0dp"
    android:layout_marginEnd="1dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#FFF9F9">

    <!-- Imagen Receta -->
    <ImageView
        android:id="@+id/vwImagen"
        android:layout_width="180dp"
        android:layout_height="150dp"
        android:background="#EBE6DF"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>


    <!-- Nombre Receta -->
        <!-- maxLines="2" : si el txNombre es largo, salta de línea máximo 2 líneas-->
    <TextView
        android:id="@+id/txNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre Receta"
        android:textStyle="bold"
        android:textSize="15dp"
        android:maxLines="2"
        android:textColor="#000000"

        android:layout_marginTop="26dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/vwImagen"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Descripción Receta-->
        <!-- maxLines="4" : si el txDescripcion es largo, salta de línea máximo 4 líneas-->
        <!-- ellipsize="end" : cuando se hay más texto del q puede salir en pantalla, en vez de cortarse usa "..." al final-->

    <!-- Dificultad -->

    <TextView
    android:id="@+id/txDescripcion"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="Breve descripción de la receta"
    android:textSize="15dp"
    android:maxLines="4"
    android:ellipsize="end"

    android:layout_marginEnd="10dp"

    app:layout_constraintStart_toStartOf="@id/txNombre"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/txNombre"/>


    <TextView
        android:id="@+id/tvDificultad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dificultad"
        android:textSize="12dp"
        android:layout_marginTop="5dp"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/vwImagen"/>

    <!-- Imagen Fav Estrella  -->
    <ImageView
        android:id="@+id/Estrella"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@android:drawable/btn_star_big_off"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
