<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#90EE90">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITULO -->
            <!-- 1.- Damos nombre-->
            <!-- 2.- Ajustamos ancho y alto a las necesidades del contenido-->
            <!-- 3.- Texto del titulo-->
            <!-- 4.- Tamaño del texto-->
            <!-- 5.- Convertimos el tipo de texto a negrita con "bold" (normal seria "normal" y cursiva seria "italic"-->
            <!-- 6.- Damos color al titulo-->
            <!-- 7.- Definimos el margen al rededor del texto-->
            <!-- 8.- Anclamos el texto a la parte superior y a los dos lados (va al centro) del contenedor principal -->

        <!-- CATEGORIA HEALTH -->
        <!-- cardCornerRadius se ocupa de redondear las esquinas de la etiqueta (no es realmente necesario en este diseño") -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/categoriaHealth"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_margin="0dp"
            app:cardCornerRadius="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/health"
                    android:scaleType="centerCrop"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#80000000" />
                    <!-- #80 es el nivel de opacidad (50% en este caso) y 000000 es el color negro -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HEALTH"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_gravity="center"/>

            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- CATEGORIA Entrantes -->
