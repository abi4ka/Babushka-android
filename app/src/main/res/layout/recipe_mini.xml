<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp"
    android:background="@color/bg_card">

    <ImageView
        android:id="@+id/imageMiniRecipe"
        android:layout_width="180dp"
        android:layout_height="150dp"
        android:background="@drawable/empty_image_background"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/titleMiniRecipe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"

        android:ellipsize="end"
        android:maxLines="2"
        android:text="Name"

        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/imageMiniRecipe"
        app:layout_constraintTop_toTopOf="@id/imageMiniRecipe" />

    <ImageView
        android:id="@+id/logoTimeMiniRecipe"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginTop="4dp"

        android:src="@android:drawable/ic_lock_idle_alarm"
        app:layout_constraintStart_toStartOf="@id/titleMiniRecipe"
        app:layout_constraintTop_toBottomOf="@id/titleMiniRecipe" />

    <TextView
        android:id="@+id/timeMiniRecipe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"

        android:text="Time"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"

        app:layout_constraintStart_toEndOf="@id/logoTimeMiniRecipe"
        app:layout_constraintTop_toTopOf="@id/logoTimeMiniRecipe" />

    <ImageView
        android:id="@+id/logoDifficultyMiniRecipe"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginStart="8dp"
        android:src="@android:drawable/ic_menu_sort_by_size"

        app:layout_constraintStart_toEndOf="@id/timeMiniRecipe"
        app:layout_constraintTop_toTopOf="@id/timeMiniRecipe" />

    <TextView
        android:id="@+id/difficultyMiniRecipe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"

        android:text="Dificullty"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"

        app:layout_constraintStart_toEndOf="@id/logoDifficultyMiniRecipe"
        app:layout_constraintTop_toTopOf="@id/logoDifficultyMiniRecipe" />

    <TextView
        android:id="@+id/descriptionMiniRecipe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="10dp"

        android:ellipsize="end"
        android:maxLines="4"
        android:text="Recipe description"
        android:textColor="@color/text_hint"
        android:textSize="14sp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/imageMiniRecipe"
        app:layout_constraintTop_toBottomOf="@id/difficultyMiniRecipe" />


    <ImageView
        android:id="@+id/starMiniRecipe"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:src="@android:drawable/btn_star_big_off"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
