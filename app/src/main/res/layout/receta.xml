<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Nombre Receta -->
        <TextView
            android:id="@+id/txNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nombre Receta"
            android:textStyle="bold"
            android:textSize="30sp"
            android:textColor="@color/text_primary"

            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Imagen Receta -->
        <ImageView
            android:id="@+id/vwImagen"
            android:layout_width="0dp"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:background="@drawable/empty_image_background"

            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/space"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <View
            android:id="@+id/space"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_weight="1"

            app:layout_constraintTop_toBottomOf="@id/txNombre"
            tools:ignore="MissingConstraints" />

        <!-- ESTRELLA DE FAVORITOS -->
        <ImageView
            android:id="@+id/Estrella"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/btn_star_big_off"

            android:layout_marginBottom="5dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="@id/tvDificultad"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- FACTOR TIEMPO PREPARACIÓN -->
        <ImageView
            android:id="@+id/ivTiempo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_idle_alarm"

            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@id/txNombre"
            app:layout_constraintTop_toBottomOf="@id/txNombre"/>
        <TextView
            android:id="@+id/tvTiempo"
            android:textColor="@color/text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiempo"
            android:textSize="14sp"

            android:layout_marginStart="6dp"
            app:layout_constraintStart_toEndOf="@id/ivTiempo"
            app:layout_constraintTop_toTopOf="@id/ivTiempo"/>

        <!-- FACTOR DIFICULTAD PREPARACIÓN -->
        <ImageView
            android:id="@+id/ivDificultad"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_sort_by_size"

            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/tvTiempo"
            app:layout_constraintTop_toTopOf="@id/tvTiempo"/>
        <TextView
            android:id="@+id/tvDificultad"
            android:textColor="@color/text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dificultad"
            android:textSize="14sp"

            android:layout_marginStart="6dp"
            app:layout_constraintStart_toEndOf="@id/ivDificultad"
            app:layout_constraintTop_toTopOf="@id/ivDificultad"/>

        <!-- Descripción -->
        <TextView
            android:id="@+id/txDescripcion"
            android:textColor="@color/text_secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Breve descripción de la receta"
            android:textSize="18sp"

            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/vwImagen"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Ingredientes título -->
        <TextView
            android:id="@+id/Ingredientes"
            android:textColor="@color/text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ingredientes:"
            android:textStyle="bold"
            android:textSize="18sp"

            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/txDescripcion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Ingredientes texto -->
        <TextView
            android:id="@+id/txIngredientes"
            android:textColor="@color/text_secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="lista ingredientes"
            android:textSize="18sp"

            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"

            app:layout_constraintTop_toBottomOf="@id/Ingredientes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Preparación título -->
        <TextView
            android:id="@+id/Preparacion"
            android:textColor="@color/text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Preparación:"
            android:textStyle="bold"
            android:textSize="18sp"

            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"

            app:layout_constraintTop_toBottomOf="@id/txIngredientes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Preparación texto -->
        <TextView
            android:id="@+id/txPreparacion"
            android:textColor="@color/text_secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="lista preparación"
            android:textSize="18sp"

            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"

            app:layout_constraintTop_toBottomOf="@id/Preparacion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/end_page_space"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            app:layout_constraintTop_toBottomOf="@id/txPreparacion"
            tools:ignore="MissingConstraints" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
