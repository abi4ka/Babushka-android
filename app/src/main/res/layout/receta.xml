<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Imagen Fav Estrella  -->
    <ImageView
        android:id="@+id/Estrella"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/btn_star_big_off"
        android:layout_marginTop="20dp"
        android:layout_marginRight="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Nombre Receta -->
    <!-- maxLines="2" : si el txNombre es largo, salta de línea máximo 2 líneas-->
    <TextView
        android:id="@+id/txNombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre Receta"
        android:textStyle="bold"
        android:textSize="30dp"
        android:maxLines="2"
        android:textColor="#000000"
        android:layout_marginTop="35dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
    />

    <!-- Imagen Receta -->
    <ImageView
        android:id="@+id/vwImagen"
        android:layout_width="350dp"
        android:layout_height="250dp"
        android:background="#FACFFF"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txNombre"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:scaleType="centerCrop"
    />

    <!-- Descripción Receta-->
    <!-- maxLines="4" : si el txDescripcion es largo, salta de línea máximo 4 líneas-->
    <!-- ellipsize="end" : cuando se hay más texto del q puede salir en pantalla, en vez de cortarse usa "..." al final-->
    <TextView
        android:id="@+id/txDescripcion"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text="Breve descripción de la receta"
        android:textSize="18dp"
        android:maxLines="4"
        android:ellipsize="end"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/vwImagen"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
    />

    <!-- Ingredientes Receta -->
    <TextView
        android:id="@+id/txIngredientes"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text="Ingredientes: "
        android:textSize="18dp"
        android:maxLines="10"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/txDescripcion"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    
    <!-- Preparación Receta -->
    <TextView
        android:id="@+id/txPreparacion"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text="Preparación:"
        android:textSize="18dp"
        android:maxLines="30"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/txIngredientes"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>